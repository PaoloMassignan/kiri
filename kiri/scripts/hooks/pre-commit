#!/bin/bash
# Pre-commit hook: block commits that contain API keys.
#
# Catches:
#   - Gateway keys (gw-...) — developer proxy tokens
#   - Real Anthropic keys (sk-ant-...) — upstream API credentials
#
# Install: bash scripts/install-hooks.sh

FAILED=0

# Gateway keys: gw- followed by 20+ base64url chars
if git diff --cached | grep -qE '^\+[^+].*gw-[A-Za-z0-9_-]{20,}'; then
    echo ""
    echo "ERROR: Staged changes appear to contain a gateway key (gw-...)."
    echo "  Remove the key from the staged files before committing."
    FAILED=1
fi

# Real Anthropic keys: sk-ant-api followed by alphanumeric chars
if git diff --cached | grep -qE '^\+[^+].*sk-ant-api[0-9A-Za-z_-]{10,}'; then
    echo ""
    echo "ERROR: Staged changes appear to contain an Anthropic API key (sk-ant-...)."
    echo "  Remove the key from the staged files before committing."
    FAILED=1
fi

if [ "$FAILED" -eq 1 ]; then
    echo ""
    echo "  If this is a false positive, use: git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
